#!/bin/sh
# Pre-commit hook for the piccle engine.
# Activated through the repository-local core.hooksPath set by `cargo setup`.
# CI remains the authoritative gate; this is a fast-feedback convenience.
# Bypass for a WIP commit: git commit --no-verify

set -e

echo '+cargo +nightly fmt --all -- --check'
cargo +nightly fmt --all -- --check

echo '+cargo clippy --workspace --all-targets -- -D warnings'
cargo clippy --workspace --all-targets -- -D warnings

echo '+typos'
typos

echo '+dprint check'
dprint check
